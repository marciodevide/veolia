trigger OpportunityTrigger on Opportunity (before insert, before update, before delete, after insert, after update, after delete, after undelete) {
	new Triggers()
        
        .bind(Triggers.Evt.beforeUpdate, new OpportunityTriggerHandler())
        .bind(Triggers.Evt.beforeInsert, new OpportunityTriggerHandler())
        
        
        .manage();
}