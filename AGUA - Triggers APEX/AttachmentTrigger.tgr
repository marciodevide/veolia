trigger AttachmentTrigger on Adjuntos_Aprobacion__c (before insert, before update, before delete, after insert, after update, after delete, after undelete) {
	new Triggers()
        
        .bind(Triggers.Evt.beforeUpdate, new AttachmentTriggerHandler())
        .bind(Triggers.Evt.beforeInsert, new AttachmentTriggerHandler())
        
        
        .manage();
}