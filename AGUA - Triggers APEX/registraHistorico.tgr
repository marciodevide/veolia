                entradaHistorico.PRODH_TXT_Valor_anterior__c = string.valueof(Trigger.oldMap.get(a.Id).OP_POR_PorcentajeDescuento__c);
                entradaHistorico.PRODH_TXT_Valor_nuevo__c = string.valueof(a.OP_POR_PorcentajeDescuento__c);
                entradaHistorico.PRODH_TXT_Usuario_modificacion__c = string.valueof(UserInfo.getname());
                entradaHistorico.PRODH_TXT_Fecha_modificacion__c = a.LastModifiedDate;
                entradaHistorico.HIS_LKP_Oportunidad__c = a.OP_MD_Oportunidad__c;
                historico.add(entradaHistorico);
