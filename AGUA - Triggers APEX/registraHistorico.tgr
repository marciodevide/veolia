                AQUA_Historico_productos_de_oportunidad__c entradaHistorico = new AQUA_Historico_productos_de_oportunidad__c();
                entradaHistorico.PRODH_TXT_Tipo_modificacion__c = 'Edit';
                entradaHistorico.PRODH_TXT_Elemento__c = 'Price (without taxes)';
                entradaHistorico.PRODH_TXT_Valor_anterior__c = string.valueof(Trigger.oldMap.get(a.Id).OP_DIV_PrecioSinIVA__c);
                entradaHistorico.PRODH_TXT_Valor_nuevo__c = string.valueof(a.OP_DIV_PrecioSinIVA__c);
